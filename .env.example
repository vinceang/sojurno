# Sojurno — offline generator/export secrets (scripts only — NEVER imported by client code).
# Copy to `.env` and fill in. `.env` is git-ignored.

# OpenAI — listing copy (structured outputs) + images (gpt-image-1).
# Get a key at https://platform.openai.com/api-keys (prepaid credits required; this is NOT the
# ChatGPT Plus subscription). gpt-image-1 may require one-time org identity verification.
OPENAI_API_KEY=sk-...

# Supabase — generator/export target. Project URL + SERVICE ROLE key (bypasses RLS; bulk writes).
# Settings → API in the Supabase dashboard. Keep the service role key secret.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Runtime client (ADR-0026): live writes + reads for user-created listings. ---
# These VITE_ vars ARE shipped in the client bundle — only safe values (anon key, demo creds).
# The ANON/publishable key + RLS gate writes; the curated 29 read from the build-time export.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
# Shared "Test User" demo account (seed it in Supabase → Authentication → Add user, email-confirmed).
# The login form signs into this single account; RLS limits writes to its own rows.
VITE_DEMO_EMAIL=demo@sojurno.com
VITE_DEMO_PASSWORD=change-me
