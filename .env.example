# Sojurno — offline generator/export secrets (scripts only — NEVER imported by client code).
# Copy to `.env` and fill in. `.env` is git-ignored.

# OpenAI — listing copy (structured outputs) + images (gpt-image-1).
# Get a key at https://platform.openai.com/api-keys (prepaid credits required; this is NOT the
# ChatGPT Plus subscription). gpt-image-1 may require one-time org identity verification.
OPENAI_API_KEY=sk-...

# Supabase — generator/export target. Project URL + SERVICE ROLE key (bypasses RLS; bulk writes).
# Settings → API in the Supabase dashboard. Keep the service role key secret.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Future: runtime browser reads (NOT used today; app reads the build-time export). ---
# When/if we flip the read seam to runtime fetch, the client uses the ANON key + RLS:
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...
